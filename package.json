{
  "name": "sm-church-app",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo-google-fonts/outfit": "^0.3.0",
    "@expo/vector-icons": "^14.0.0",
    "@react-navigation/bottom-tabs": "^7.0.5",
    "@react-navigation/native": "^7.0.3",
    "@react-navigation/native-stack": "^7.3.10",
    "@react-navigation/stack": "^7.0.4",
    "@tamagui/animations-react-native": "^1.125.8",
    "@tamagui/font-inter": "^1.125.8",
    "@tamagui/react-native-media-driver": "^1.125.8",
    "@tamagui/shorthands": "^1.125.8",
    "@tamagui/themes": "^1.125.8",
    "axios": "^1.8.4",
    "date-fns": "^4.1.0",
    "expo": "^52.0.44",
    "expo-dev-client": "~5.0.4",
    "expo-dev-launcher": "^5.0.17",
    "expo-font": "~13.0.4",
    "expo-localization": "~16.0.1",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.22",
    "expo-status-bar": "~2.0.1",
    "firebase": "^10.5.2",
    "i18next": "^23.7.20",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^14.0.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "tamagui": "^1.125.8",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@tamagui/babel-plugin": "^1.125.8",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^12.0.1",
    "eslint-plugin-testing-library": "^7.1.1",
    "jest": "~29.7.0",
    "jest-expo": "~52.0.6",
    "prettier": "^3.2.5",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.3.3"
  },
  "eslintConfig": {
    "extends": [
      "universe/native",
      "universe/shared/typescript-analysis"
    ],
    "overrides": [
      {
        "files": [
          "**/__tests__/**/*.[jt]s?(x)",
          "**/?(*.)+(spec|test).[jt]s?(x)"
        ],
        "extends": [
          "plugin:testing-library/react"
        ]
      },
      {
        "files": [
          "*.ts",
          "*.tsx",
          "*.d.ts"
        ],
        "parserOptions": {
          "project": "./tsconfig.json"
        },
        "rules": {
          "@typescript-eslint/no-unused-vars": [
            "error",
            {
              "argsIgnorePattern": "^_"
            }
          ],
          "complexity": "warn"
        }
      }
    ],
    "root": true
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  },
  "main": "node_modules/expo/AppEntry.js",
  "private": true
}
