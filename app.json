{
  "expo": {
    "name": "SanMateoIglesiaEpiscopal",
    "slug": "sm-church-app",
    "version": "1.0.1",
    // "version": "1.0.2", // Android
    "web": {
      "favicon": "./assets/icon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store",
      "expo-font",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "resizeMode": "native",
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBMessaging", "RNFBStorage"]
          }
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "The app needs to access your calendar.",
          "remindersPermission": "The app needs to access your reminders."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Iglesia San Mateo App requiere acceso a tu galería para que puedas elegir una imagen y personalizar tu foto de perfil dentro de la aplicación."
        }
      ]
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "backgroundColor": "#00000000",
      "translucent": true
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.lestherccoroneldev.smchurchapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification", "fetch"],
        "NSPhotoLibraryUsageDescription": "Iglesia San Mateo App requiere acceso a tu galería para que puedas elegir una imagen y personalizar tu foto de perfil dentro de la aplicación."
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lestherccoroneldev.smchurchapp",
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "3ffce132-ac8c-4eb1-9f90-2246294fc13b"
      }
    }
  }
}
