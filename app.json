{
  "expo": {
    "name": "San Mateo Iglesia Episcopal",
    "slug": "sm-church-app",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/icon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-localization",
      [
        "expo-dev-launcher",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "imageWidth": 280,
          "resizeMode": "native",
          "backgroundColor": "#ffffff",
          "image": "./assets/logo-san-mateo.png"
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lestherccoroneldev.smchurchapp",
      "jsEngine": "jsc"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lestherccoroneldev.smchurchapp",
      "jsEngine": "hermes"
    },
    "extra": {
      "eas": {
        "projectId": "3ffce132-ac8c-4eb1-9f90-2246294fc13b"
      }
    }
  }
}
